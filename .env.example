# Ollama service URL (use http://ollama:11434 in Docker, http://localhost:11434 locally)
OLLAMA_BASE_URL=http://ollama:11434

# Qdrant service URL (use http://qdrant:6333 in Docker, http://localhost:6333 locally)
QDRANT_URL=http://qdrant:6333

# LLM model to use for summarisation and chat
OLLAMA_MODEL=llama3.2:3b

# Embedding model
OLLAMA_EMBED_MODEL=nomic-embed-text
